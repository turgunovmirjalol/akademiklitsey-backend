# Django
DEBUG=True
SECRET_KEY=your-very-strong-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com

# Database konfiguratsiyasi
# 1-usul: SQLite (tez va oson, local uchun, serverda ham ishlaydi)
USE_SQLITE=True

# 2-usul: DATABASE_URL (Digital Ocean managed DB yoki boshqa PostgreSQL uchun
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# 3-usul: PostgreSQL alohida parametrlar
# DB_NAME=academik_litsey
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# CORS — frontend domenini kiriting
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
